# ════════════════════════════════════════════════
# AgentPal 环境配置模板
# 复制此文件为 .env 并填写实际值
# ════════════════════════════════════════════════

# ─── 应用配置 ────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8088
APP_SECRET_KEY=change-me-to-a-random-secret

# ─── LLM 配置 ────────────────────────────────────
# AgentScope 支持的模型名，例如 qwen-max, gpt-4o 等
LLM_PROVIDER=dashscope       # dashscope | openai | anthropic
LLM_MODEL=qwen-max
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=                # 可选，自定义 API 地址

# ─── DingTalk 钉钉 ───────────────────────────────
DINGTALK_ENABLED=false
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_WEBHOOK_TOKEN=      # 群机器人 Token（可选）

# ─── 飞书 Feishu / Lark ──────────────────────────
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=          # 可选，消息加密

# ─── iMessage（仅 macOS）────────────────────────
IMESSAGE_ENABLED=false
IMESSAGE_MY_PHONE=           # 发送方手机号（可选提示）

# ─── 数据存储 ────────────────────────────────────
DATABASE_URL=sqlite:///./agentpal.db
# 生产环境推荐使用 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agentpal

# ─── Redis（可选，用于任务队列）──────────────────
REDIS_URL=redis://localhost:6379/0

# ─── 日志 ────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json              # json | text

# ─── CORS（前端地址）────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
